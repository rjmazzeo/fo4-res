# Ensure shell scripts always use LF line endings
*.sh text eol=lf

# Ensure batch files use CRLF line endings (Windows standard)
*.bat text eol=crlf

# Python files can use either, but prefer LF
*.py text

# Text files default to LF
*.txt text eol=lf
*.md text eol=lf

# INI files use LF
*.ini text eol=lf
